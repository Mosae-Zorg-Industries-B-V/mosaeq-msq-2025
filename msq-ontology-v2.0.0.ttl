@prefix msq:    <https://msq.mosaeq.com/ontology#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

# ──────────────────────────────────────────────────────────────
# msq: Quantum Safety Ontology
# Namespace: https://msq.mosaeq.com/ontology#
# Version:   2.0.0
# Publisher: Mosae Zorg Industries UG (haftungsbeschraenkt)
# License:   Commercial — partnerships@mosaeq.com
# ──────────────────────────────────────────────────────────────

<https://msq.mosaeq.com/ontology> a owl:Ontology ;
    owl:versionInfo "2.0.0" ;
    owl:priorVersion <https://msq.mosaeq.com/ontology/1.0.0> ;
    dcterms:title "msq Quantum Safety Ontology"@en ;
    dcterms:description "Quantum ontology encoding molecular entities as quaternion coordinates on S\u00B3 for translational preclinical safety concordance."@en ;
    dcterms:publisher "Mosae Zorg Industries UG (haftungsbeschraenkt)" ;
    dcterms:creator "F. Hanna Campbell" ;
    dcterms:created "2026-04-03"^^xsd:date ;
    dcterms:modified "2026-04-04"^^xsd:date ;
    dcterms:license "Commercial — partnerships@mosaeq.com" .

# ══════════════════════════════════════════════════════════════
#  LAYER 1: CORE ENTITY MODEL
# ══════════════════════════════════════════════════════════════

msq:Compound a owl:Class ;
    rdfs:label "Compound"@en ;
    rdfs:comment "A molecular entity subject to safety concordance analysis."@en .

msq:S3Coordinate a owl:Class ;
    rdfs:label "S3Coordinate"@en ;
    rdfs:comment "Quaternion coordinate (theta, phi) on the three-sphere S\u00B3, computed from LogP and TPSA via NEMP."@en .

# ══════════════════════════════════════════════════════════════
#  LAYER 2: TRAP ZONES
# ══════════════════════════════════════════════════════════════

msq:TrapZone a owl:Class ;
    rdfs:label "TrapZone"@en ;
    rdfs:comment "Tissue accumulation zone on S\u00B3 where compounds concentrate before clinical exposure."@en .

# ── TrapZone subclasses (9) ──

msq:BrainTrap a owl:Class ;
    rdfs:subClassOf msq:TrapZone ;
    rdfs:label "Brain Trap"@en ;
    rdfs:comment "BBB-penetrating compounds. High lipophilicity + low polar surface area enables CNS entry."@en .

msq:LysosomalTrap a owl:Class ;
    rdfs:subClassOf msq:TrapZone ;
    rdfs:label "Lysosomal Trap"@en ;
    rdfs:comment "Lysosomotropic accumulation via ion trapping in acidic organelles."@en .

msq:GutTrap a owl:Class ;
    rdfs:subClassOf msq:TrapZone ;
    rdfs:label "Gut Trap"@en ;
    rdfs:comment "GI mucosa sequestration causing nausea and emesis."@en .

msq:PlasmaRetained a owl:Class ;
    rdfs:subClassOf msq:TrapZone ;
    rdfs:label "Plasma-Retained"@en ;
    rdfs:comment "Hydrophilic compounds that remain in circulation with lowest tissue-trap risk."@en .

msq:HepaticTrap a owl:Class ;
    rdfs:subClassOf msq:TrapZone ;
    rdfs:label "Hepatic Trap"@en ;
    rdfs:comment "Hepatocyte accumulation driven by active uptake transporters and first-pass metabolism."@en .

msq:RenalTrap a owl:Class ;
    rdfs:subClassOf msq:TrapZone ;
    rdfs:label "Renal Trap"@en ;
    rdfs:comment "Proximal tubule accumulation via organic cation/anion transporters."@en .

msq:PulmonaryTrap a owl:Class ;
    rdfs:subClassOf msq:TrapZone ;
    rdfs:label "Pulmonary Trap"@en ;
    rdfs:comment "Lung tissue sequestration of basic lipophilic amines."@en .

msq:CardiacTrap a owl:Class ;
    rdfs:subClassOf msq:TrapZone ;
    rdfs:label "Cardiac Trap"@en ;
    rdfs:comment "Myocardial accumulation with hERG channel interaction risk."@en .

msq:IntermediateZone a owl:Class ;
    rdfs:subClassOf msq:TrapZone ;
    rdfs:label "Intermediate Zone"@en ;
    rdfs:comment "Compound falls between primary trap zones on S\u00B3."@en .

# ══════════════════════════════════════════════════════════════
#  LAYER 3a: SAFETY & CONCORDANCE
# ══════════════════════════════════════════════════════════════

msq:SafetyProfile a owl:Class ;
    rdfs:label "SafetyProfile"@en ;
    rdfs:comment "Aggregate safety assessment combining trap zone classification, concordance data, and risk scores."@en .

msq:OpioidPanel a owl:Class ;
    rdfs:label "OpioidPanel"@en ;
    rdfs:comment "CNS and opioid receptor safety screening panel triggered by BBB penetration or hERG risk."@en .

msq:Concordance a owl:Class ;
    rdfs:label "Concordance"@en ;
    rdfs:comment "Agreement between predicted safety profile and real-world pharmacovigilance outcomes."@en .

msq:DigitalCliff a owl:Class ;
    rdfs:label "DigitalCliff"@en ;
    rdfs:comment "Systematic absence of a clinically validated drug from a regulatory database (e.g., FDA FAERS NOT_FOUND for non-US-marketed drugs)."@en .

msq:DataSource a owl:Class ;
    rdfs:label "DataSource"@en ;
    rdfs:comment "Public pharmacovigilance or toxicogenomics database integrated into the concordance pipeline."@en .

msq:EnvironmentalFate a owl:Class ;
    rdfs:label "EnvironmentalFate"@en ;
    rdfs:comment "Environmental persistence and ecological impact profile of a compound (EcoFate analysis)."@en .

msq:AuxiliaryMetabolicGene a owl:Class ;
    rdfs:label "AuxiliaryMetabolicGene"@en ;
    rdfs:comment "Gene encoding auxiliary metabolic function in viral or microbial genomes, relevant to pathogen surveillance."@en .

msq:AntiDefenseGene a owl:Class ;
    rdfs:label "AntiDefenseGene"@en ;
    rdfs:comment "Gene encoding mechanisms that counteract host immune defenses."@en .

msq:ViralLifecycle a owl:Class ;
    rdfs:label "ViralLifecycle"@en ;
    rdfs:comment "Classification of viral replication strategy (lytic, lysogenic, chronic) relevant to outbreak surveillance."@en .

# ══════════════════════════════════════════════════════════════
#  LAYER 3b: EFFLUX TRANSPORTERS
# ══════════════════════════════════════════════════════════════

msq:EffluxTransporter a owl:Class ;
    rdfs:label "EffluxTransporter"@en ;
    rdfs:comment "Membrane transporter that actively exports compounds from cells, modulating tissue accumulation."@en .

# ══════════════════════════════════════════════════════════════
#  LAYER 3c: REGULATORY STATUS
# ══════════════════════════════════════════════════════════════

msq:RegulatoryStatus a owl:Class ;
    rdfs:label "RegulatoryStatus"@en ;
    rdfs:comment "Regulatory classification of a compound within a specific framework and jurisdiction."@en .

msq:RegulatoryDatabase a owl:Class ;
    rdfs:subClassOf msq:DataSource ;
    rdfs:label "RegulatoryDatabase"@en ;
    rdfs:comment "Authoritative regulatory database that publishes substance status, restrictions, and concentration limits."@en .

# ── Regulatory datatype properties ──

msq:statusType a owl:DatatypeProperty ;
    rdfs:label "statusType"@en ;
    rdfs:domain msq:RegulatoryStatus ;
    rdfs:range xsd:string ;
    rdfs:comment "Regulatory status classification. Valid values: BANNED, RESTRICTED, PERMITTED, PERMITTED_WITH_CONDITIONS, SVHC, NOT_ASSESSED."@en .

msq:regulatoryFramework a owl:DatatypeProperty ;
    rdfs:label "regulatoryFramework"@en ;
    rdfs:domain msq:RegulatoryStatus ;
    rdfs:range xsd:string ;
    rdfs:comment "Legal or regulatory framework under which the status applies. Valid values: REACH, CLP, CosIng_AnnexII, CosIng_AnnexIII, CosIng_AnnexIV, CosIng_AnnexV, CosIng_AnnexVI, IFRA, SCCS, FDA_CFR, TSCA, EU_BPR."@en .

msq:maxConcentrationPercent a owl:DatatypeProperty ;
    rdfs:label "maxConcentrationPercent"@en ;
    rdfs:domain msq:RegulatoryStatus ;
    rdfs:range xsd:float ;
    rdfs:comment "Maximum permitted concentration as a percentage (e.g., 0.01 means max 0.01%)."@en .

msq:restrictionCondition a owl:DatatypeProperty ;
    rdfs:label "restrictionCondition"@en ;
    rdfs:domain msq:RegulatoryStatus ;
    rdfs:range xsd:string ;
    rdfs:comment "Human-readable restriction condition (e.g., 'max 0.01% in leave-on products')."@en .

# ── Regulatory object property ──

msq:hasRegulatoryStatus a owl:ObjectProperty ;
    rdfs:label "hasRegulatoryStatus"@en ;
    rdfs:domain msq:Compound ;
    rdfs:range msq:RegulatoryStatus ;
    rdfs:comment "Links a compound to one or more regulatory status records."@en .

# ── RegulatoryDatabase individuals ──

msq:ECHA a msq:RegulatoryDatabase ;
    rdfs:label "ECHA"@en ;
    rdfs:comment "European Chemicals Agency — administers REACH, CLP, and Biocidal Products Regulation."@en .

msq:CosIng a msq:RegulatoryDatabase ;
    rdfs:label "CosIng"@en ;
    rdfs:comment "European Commission Cosmetic Ingredient database — Annexes II through VI."@en .

msq:IFRAdb a msq:RegulatoryDatabase ;
    rdfs:label "IFRA"@en ;
    rdfs:comment "International Fragrance Association Standards — fragrance ingredient safety limits."@en .

msq:SCCSdb a msq:RegulatoryDatabase ;
    rdfs:label "SCCS"@en ;
    rdfs:comment "Scientific Committee on Consumer Safety — EU scientific opinions on cosmetic ingredients."@en .

# ══════════════════════════════════════════════════════════════
#  CORE PROPERTIES
# ══════════════════════════════════════════════════════════════

msq:hasS3Coordinate a owl:ObjectProperty ;
    rdfs:label "hasS3Coordinate"@en ;
    rdfs:domain msq:Compound ;
    rdfs:range msq:S3Coordinate .

msq:hasTrapZone a owl:ObjectProperty ;
    rdfs:label "hasTrapZone"@en ;
    rdfs:domain msq:Compound ;
    rdfs:range msq:TrapZone .

msq:hasSafetyProfile a owl:ObjectProperty ;
    rdfs:label "hasSafetyProfile"@en ;
    rdfs:domain msq:Compound ;
    rdfs:range msq:SafetyProfile .

msq:hasConcordance a owl:ObjectProperty ;
    rdfs:label "hasConcordance"@en ;
    rdfs:domain msq:Compound ;
    rdfs:range msq:Concordance .

msq:hasDataSource a owl:ObjectProperty ;
    rdfs:label "hasDataSource"@en ;
    rdfs:domain msq:Concordance ;
    rdfs:range msq:DataSource .

msq:computationRunID a owl:DatatypeProperty ;
    rdfs:label "computation run ID"@en ;
    rdfs:range xsd:string ;
    rdfs:comment """Unique identifier linking this ontology classification to the quantum computation that produced the input property values. Format: run-{timestamp}. Stored in Supabase with input SMILES, timestamp, and user ID. The computation is performed by patent-protected technology on secure infrastructure owned by Mosae Zorg Industries UG. The computation method is not specified in this ontology."""@en .

msq:hasEnvironmentalFate a owl:ObjectProperty ;
    rdfs:label "hasEnvironmentalFate"@en ;
    rdfs:domain msq:Compound ;
    rdfs:range msq:EnvironmentalFate .

msq:theta a owl:DatatypeProperty ;
    rdfs:label "theta"@en ;
    rdfs:domain msq:S3Coordinate ;
    rdfs:range xsd:double ;
    rdfs:comment "Polar angle on S\u00B3, computed from LogP."@en .

msq:phi a owl:DatatypeProperty ;
    rdfs:label "phi"@en ;
    rdfs:domain msq:S3Coordinate ;
    rdfs:range xsd:double ;
    rdfs:comment "Azimuthal angle on S\u00B3, computed from TPSA."@en .

msq:logP a owl:DatatypeProperty ;
    rdfs:label "logP"@en ;
    rdfs:domain msq:Compound ;
    rdfs:range xsd:double .

msq:tpsa a owl:DatatypeProperty ;
    rdfs:label "tpsa"@en ;
    rdfs:domain msq:Compound ;
    rdfs:range xsd:double ;
    rdfs:comment "Topological polar surface area in Angstrom squared."@en .

msq:pka a owl:DatatypeProperty ;
    rdfs:label "pka"@en ;
    rdfs:domain msq:Compound ;
    rdfs:range xsd:double .

msq:concordanceScore a owl:DatatypeProperty ;
    rdfs:label "concordanceScore"@en ;
    rdfs:domain msq:Concordance ;
    rdfs:range xsd:double ;
    rdfs:comment "Numerical concordance score between predicted and observed safety outcomes."@en .

# ══════════════════════════════════════════════════════════════
#  DATA SOURCE INSTANCES
# ══════════════════════════════════════════════════════════════

msq:FAERS a msq:DataSource ;
    rdfs:label "FDA FAERS"@en ;
    rdfs:comment "Post-market adverse event reporting system."@en .

msq:DrugMatrix a msq:DataSource ;
    rdfs:label "NTP DrugMatrix"@en ;
    rdfs:comment "Repeat-dose histopathology database."@en .

msq:TGGATEs a msq:DataSource ;
    rdfs:label "Open TG-GATEs"@en ;
    rdfs:comment "Toxicogenomics database."@en .

msq:DailyMed a msq:DataSource ;
    rdfs:label "NLM DailyMed"@en ;
    rdfs:comment "FDA-approved drug labels."@en .

msq:EudraVigilance a msq:DataSource ;
    rdfs:label "EudraVigilance"@en ;
    rdfs:comment """European Medicines Agency pharmacovigilance database. Adverse drug reaction reports from EU/EEA."""@en ;
    msq:sourceURL "https://www.adrreports.eu/"^^xsd:anyURI .

msq:EARSNet a msq:DataSource ;
    rdfs:label "EARS-Net"@en ;
    rdfs:comment """European Antimicrobial Resistance Surveillance Network. AMR data from 30 EU/EEA countries."""@en ;
    msq:sourceURL "https://www.ecdc.europa.eu/"^^xsd:anyURI .

msq:ClinVarDB a msq:DataSource ;
    rdfs:label "ClinVar"@en ;
    rdfs:comment """NCBI database of genetic variants and their clinical significance."""@en ;
    msq:sourceURL "https://www.ncbi.nlm.nih.gov/clinvar/"^^xsd:anyURI .

msq:OrphanetDB a msq:DataSource ;
    rdfs:label "Orphanet"@en ;
    rdfs:comment """Rare disease database with genes, clinical signs, and management. ORDO codes are the standard identifiers for rare diseases."""@en ;
    msq:sourceURL "https://www.orpha.net/"^^xsd:anyURI .

msq:GWASCatalog a msq:DataSource ;
    rdfs:label "GWAS Catalog"@en ;
    rdfs:comment """NHGRI-EBI Catalog of Genome-Wide Association Studies. Links genetic variants to disease traits."""@en ;
    msq:sourceURL "https://www.ebi.ac.uk/gwas/"^^xsd:anyURI .

msq:SINList a msq:DataSource ;
    rdfs:label "SIN List"@en ;
    rdfs:comment """ChemSec Substitute It Now list. Chemicals identified as needing substitution based on SVHC criteria."""@en ;
    msq:sourceURL "https://sinlist.chemsec.org/"^^xsd:anyURI .

msq:NORMANNetwork a msq:DataSource ;
    rdfs:label "NORMAN Network"@en ;
    rdfs:comment """Network of reference laboratories for monitoring emerging environmental substances. Over 100,000 entries."""@en ;
    msq:sourceURL "https://www.norman-network.net/"^^xsd:anyURI .

msq:sourceURL a owl:DatatypeProperty ;
    rdfs:domain msq:DataSource ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "URL of the data source."@en .

# ══════════════════════════════════════════════════════════════
#  PRODUCT SUITE
# ══════════════════════════════════════════════════════════════

msq:Product a owl:Class ;
    rdfs:label "Product"@en ;
    rdfs:comment "A mosaeQ platform product or service."@en .

msq:productURL a owl:DatatypeProperty ;
    rdfs:domain msq:Product ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "URL of the product."@en .

msq:createEditor a msq:Product ;
    rdfs:label "create.mosaeQ.com"@en ;
    rdfs:comment "Molecular design tools. EcoFate environmental fate analysis."@en ;
    msq:productURL "https://create.mosaeQ.com"^^xsd:anyURI .

msq:ecoChain a msq:Product ;
    rdfs:label "eco.mosaeQ.com"@en ;
    rdfs:comment """Ecological safety chain and alternatives. Computes environmental fate, microbial impact, viral activation risk, and pathogen emergence prediction for any compound. Identifies safer structural alternatives with lower ecological impact."""@en ;
    msq:productURL "https://eco.mosaeQ.com"^^xsd:anyURI .
