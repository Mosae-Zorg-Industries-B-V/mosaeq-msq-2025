{
  "rewrites": [
    { "source": "/ontology/msq-ontology-v1.0.0.ttl", "destination": "/msq-ontology-v1.0.0.ttl" },
    { "source": "/ontology.ttl", "destination": "/msq-ontology-v1.0.0.ttl" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/ontology/(.*\\.ttl)",
      "headers": [
        { "key": "Content-Type", "value": "text/turtle; charset=utf-8" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/ontology.ttl",
      "headers": [
        { "key": "Content-Type", "value": "text/turtle; charset=utf-8" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
